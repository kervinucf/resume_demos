0 0 14px; }\n  #app ul { padding-left: 20px; }\n  #app li { margin: 4px 0; }\n  #app .crumbs { margin-bottom: 14px; }\n  #app .muted { color: #555; }\n  #app pre {\n    white-space: pre-wrap;\n    word-break: break-word;\n    padding: 12px;\n    border: 1px solid #ddd;\n    background: #fafafa;\n    overflow: auto;\n  }\n  #app .section { margin-top: 18px; }\n  #app .live { display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: #22c55e; margin-right: 6px; }\n</style>\n<div id=\"app\">loading...</div>\n",">":1774597091512.007}},"js":{"":{":":"\n(function () {\n  var app = document.getElementById(\"app\");\n  if (!app || app.dataset.on) return;\n  app.dataset.on = \"1\";\n\n  // --- EXHAUSTIVE DEBUGGING: INBOUND MESH ---\n  if (window.$gun && !window.$gun._hasInboundLogger) {\n    window.$gun._hasInboundLogger = true;\n    window.$gun.on('in', function(msg) {\n      if (msg.put) {\n        console.log(\"[BROWSER MESH IN] Raw network packet received for souls:\", Object.keys(msg.put));\n      }\n      this.to.next(msg);\n    });\n  }\n  // ------------------------------------------\n\n  var renderQueued = false;\n  var mapSubCache = {};\n  var keysCache = {};\n  var nodeEv = null;\n  var nodePath = \"\";\n\n  var view = {\n    peer: \"\",\n    bucket: \"\",\n    path: \"\",\n    node: null,\n    nodeLoaded: false,\n    nodeSig: \"\"\n  };\n\n  function queueRender() {\n    if (renderQueued) return;\n    renderQueued = true;\n    requestAnimationFrame(function () {\n      renderQueued = false;\n      renderCurrentView();\n    });\n  }\n\n  function uniq(xs) {\n    var out = [], seen = {};\n    for (var i = 0; i < xs.length; i++) {\n      var x = String(xs[i] || \"\").replace(/\\/$/, \"\");\n      if (!x || seen[x]) continue;\n      seen[x] = 1;\n      out.push(x);\n    }\n    return out;\n  }\n\n  function peers() {\n    var xs = [];\n    if (Array.isArray(window.$peers)) xs = xs.concat(window.$peers);\n    xs.push(location.origin);\n    return uniq(xs);\n  }\n\n  function esc(x) {\n    return String(x == null ? \"\" : x)\n      .replace(/&/g, \"&amp;\")\n      .replace(/</g, \"&lt;\")\n      .replace(/>/g, \"&gt;\")\n      .replace(/\"/g, \"&quot;\");\n  }\n\n  function parts(path) {\n    return String(path || \"\").split(\"/\").filter(Boolean);\n  }\n\n  function join(ps) {\n    return ps.filter(Boolean).join(\"/\");\n  }\n\n  function encPath(path) {\n    return parts(path).map(encodeURIComponent).join(\"/\");\n  }\n\n  function parseHash() {\n    var q = new URLSearchParams(location.hash.replace(/^#/, \"\"));\n    return {\n      peer: q.get(\"peer\") || \"\",\n      bucket: q.get(\"bucket\") || \"\",\n      path: q.get(\"path\") || \"\"\n    };\n  }\n\n  function makeHash(st) {\n    var q = new URLSearchParams();\n    if (st.peer) q.set(\"peer\", st.peer);\n    if (st.bucket) q.set(\"bucket\", st.bucket);\n    if (st.path) q.set(\"path\", st.path);\n    return \"#\" + q.toString();\n  }\n\n  function alink(label, st) {\n    return '<a href=\"' + makeHash(st) + '\">' + esc(label) + \"</a>\";\n  }\n\n  async function getJSON(url) {\n    var r = await fetch(url, { cache: \"no-store\" });\n    if (!r.ok) throw new Error(url + \" -> HTTP \" + r.status);\n    return await r.json();\n  }\n\n  function parentPath(path) {\n    var p = parts(path);\n    if (!p.length) return \"\";\n    p.pop();\n    return join(p);\n  }\n\n  function crumbs(st) {\n    var out = [];\n    out.push(alink(\"peers\", {}));\n    if (st.peer) out.push(\" / \" + alink(st.peer, { peer: st.peer }));\n    if (st.bucket) out.push(\" / \" + alink(st.bucket, { peer: st.peer, bucket: st.bucket }));\n    if (st.path) {\n      var p = parts(st.path), acc = [];\n      for (var i = 0; i < p.length; i++) {\n        acc.push(p[i]);\n        out.push(\" / \" + alink(p[i], {\n          peer: st.peer,\n          bucket: st.bucket,\n          path: join(acc)\n        }));\n      }\n    }\n    return out.join(\"\");\n  }\n\n  function exact(keys, path) {\n    if (!path) return false;\n    for (var i = 0; i < keys.length; i++) {\n      if (keys[i] === path) return true;\n    }\n    return false;\n  }\n\n  function childrenOf(keys, prefix) {\n    var out = {};\n    var pref = prefix ? prefix + \"/\" : \"\";\n    for (var i = 0; i < keys.length; i++) {\n      var k = keys[i];\n      if (prefix) {\n        if (k !== prefix && k.indexOf(pref) !== 0) continue;\n      }\n      var rest = prefix ? (k === prefix ? \"\" : k.slice(pref.length)) : k;\n      if (!rest) continue;\n      var head = rest.split(\"/\")[0];\n      var full = prefix ? prefix + \"/\" + head : head;\n      out[full] = 1;\n    }\n    return Object.keys(out).sort();\n  }\n\n  function normalizeLinks(node, st) {\n    if (!node || !node.links) return [];\n    var raw = node.links;\n    if (typeof raw === \"string\") {\n      try { raw = JSON.parse(raw); } catch (_) { raw = []; }\n    }\n    if (!Array.isArray(raw)) return [];\n    var out = [];\n    for (var i = 0; i < raw.length; i++) {\n      var it = raw[i];\n      if (typeof it === \"string\") {\n        out.push({ label: it, peer: st.peer, bucket: st.bucket, path: it });\n        continue;\n      }\n      if (!it || !it.path) continue;\n      out.push({\n        label: it.label || it.rel || it.path,\n        peer: it.peer || st.peer,\n        bucket: it.bucket || st.bucket,\n        path: it.path\n      });\n    }\n    return out;\n  }\n\n  async function peerBuckets(peer) {\n    try {\n      var meta = await getJSON(peer + \"/\");\n      return Array.isArray(meta.buckets) ? meta.buckets.slice().sort() : [];\n    } catch (_) {\n      return [];\n    }\n  }\n\n  function sig(x) {\n    try { return JSON.stringify(x); }\n    catch (_) { return String(Math.random()); }\n  }\n\n  var CF = [\"html\",\"css\",\"js\",\"link\",\"json\",\"data\",\"meta\",\"links\",\"actions\",\"layer\",\"fixed\",\"portal\"];\n  function hasContent(d) {\n    if (!d) return false;\n    for (var i = 0; i < CF.length; i++) {\n      if (d[CF[i]] !== undefined && d[CF[i]] !== null) return true;\n    }\n    return false;\n  }\n\n  function cleanNode(d) {\n    if (!d) return null;\n    var out = {};\n    var keys = Object.keys(d);\n    for (var i = 0; i < keys.length; i++) {\n      var k = keys[i];\n      if (k === \"_\" || k === \"#\" || k === \">\") continue;\n      if (d[k] !== null) out[k] = d[k];\n    }\n    return Object.keys(out).length ? out : null;\n  }\n\n// FIXED: Subscribe directly to the absolute soul\n  function getScene(bucket) {\n    return window.$gun.get(bucket + \"/scene\");\n  }\n\n  function ensureMapSub(peer, bucket) {\n    var cacheKey = bucket;\n    if (mapSubCache[cacheKey]) return;\n\n    var scene = getScene(bucket);\n    if (!keysCache[cacheKey]) keysCache[cacheKey] = {};\n    var ks = keysCache[cacheKey];\n\n    scene.map().on(function (data, key) {\n      if (!data || key === \"_\") return;\n      var clean = cleanNode(data);\n      if (clean && hasContent(clean)) {\n        ks[key] = 1;\n      } else {\n        delete ks[key];\n      }\n\n      var st = parseHash();\n      if (st.peer === peer && st.bucket === bucket && st.path === key) {\n        var ns = sig(clean);\n        if (ns !== view.nodeSig) {\n          view.node = clean;\n          view.nodeSig = ns;\n          view.nodeLoaded = true;\n          queueRender();\n        }\n      }\n      queueRender();\n    });\n\n    mapSubCache[cacheKey] = true;\n\n    getJSON(peer + \"/\" + encodeURIComponent(bucket) + \"/api/keys\")\n      .then(function (keys) {\n        if (Array.isArray(keys)) {\n          for (var i = 0; i < keys.length; i++) ks[keys[i]] = 1;\n          queueRender();\n        }\n      })\n      .catch(function () {});\n  }\n\n  function getKeys(bucket) {\n    var ks = keysCache[bucket];\n    return ks ? Object.keys(ks).sort() : [];\n  }\n\n  function stopNodeSub() {\n    if (nodeEv) {\n      try { nodeEv.off(); } catch (_) {}\n    }\n    nodeEv = null;\n    nodePath = \"\";\n  }\n\n  function watchNode(peer, bucket, path) {\n    if (nodePath === bucket + \"|\" + path) return;\n    stopNodeSub();\n    \n    if (!path) {\n      view.node = null;\n      view.nodeLoaded = true;\n      return;\n    }\n\n    nodePath = bucket + \"|\" + path;\n    view.node = null;\n    view.nodeLoaded = false;\n    view.nodeSig = \"\";\n\n    // FIXED: Listen directly to the literal string soul the relay broadcasts\n    var targetSoul = bucket + \"/scene/\" + path;\n    \n    window.$gun.get(targetSoul).on(function (data, key, msg, ev) {\n      nodeEv = ev;\n      var st = parseHash();\n      if (st.path !== path || st.bucket !== bucket) return;\n      var clean = cleanNode(data);\n      var ns = sig(clean);\n      if (ns !== view.nodeSig) {\n        view.node = clean;\n        view.nodeSig = ns;\n        view.nodeLoaded = true;\n        console.log(\"🔥 [LIVE STREAM] UI Updated via WebSocket for:\", targetSoul);\n        queueRender();\n      }\n    });\n\n    getJSON(peer + \"/\" + encodeURIComponent(bucket) + \"/scene/\" + encPath(path))\n      .then(function (node) {\n        var st = parseHash();\n        if (st.path !== path || st.bucket !== bucket) return;\n        if (view.nodeLoaded) return;\n        view.node = cleanNode(node);\n        view.nodeSig = sig(view.node);\n        view.nodeLoaded = true;\n        queueRender();\n      })\n      .catch(function () {\n        if (!view.nodeLoaded) {\n          view.node = null;\n          view.nodeLoaded = true;\n          queueRender();\n        }\n      });\n  }\n\n  async function renderHome() {\n    var xs = peers();\n    var currentBucket = window.$bucket || \"\";\n    var rows = await Promise.all(xs.map(async function (peer) {\n      var buckets = await peerBuckets(peer);\n      return { peer: peer, buckets: buckets };\n    }));\n\n    var html = \"<div class='crumbs'>\" + crumbs({}) + \"</div>\";\n    html += \"<h1>Peers</h1>\";\n    if (currentBucket) {\n      html += \"<p class='muted'>Current bucket: <strong>\" + esc(currentBucket) + \"</strong></p>\";\n    }\n    html += \"<ul>\";\n    for (var i = 0; i < rows.length; i++) {\n      var row = rows[i];\n      html += \"<li>\" + alink(row.peer, { peer: row.peer });\n      if (currentBucket && row.buckets.indexOf(currentBucket) !== -1) {\n        html += \" - \" + alink(currentBucket, { peer: row.peer, bucket: currentBucket });\n      } else if (row.buckets.length) {\n        html += \" <span class='muted'>(\" + row.buckets.length + \" buckets)</span>\";\n      } else {\n        html += \" <span class='muted'>(unreachable or empty)</span>\";\n      }\n      html += \"</li>\";\n    }\n    html += \"</ul>\";\n    app.innerHTML = html;\n  }\n\n  async function renderBuckets(st) {\n    var buckets = await peerBuckets(st.peer);\n    var html = \"<div class='crumbs'>\" + crumbs(st) + \"</div>\";\n    html += \"<h1>\" + esc(st.peer) + \"</h1><ul>\";\n    for (var i = 0; i < buckets.length; i++) {\n      html += \"<li>\" + alink(buckets[i], { peer: st.peer, bucket: buckets[i] }) + \"</li>\";\n    }\n    html += \"</ul>\";\n    app.innerHTML = html;\n  }\n\n  function renderCurrentView() {\n    var st = { peer: view.peer, bucket: view.bucket, path: view.path };\n\n    if (!st.peer) { renderHome(); return; }\n    if (!st.bucket) { renderBuckets(st); return; }\n\n    var keys = getKeys(st.bucket);\n    var path = st.path || \"\";\n    var kids = childrenOf(keys, path);\n    var isNode = exact(keys, path);\n\n    var html = \"<div class='crumbs'>\" + crumbs(st) + \"</div>\";\n    html += \"<p>\" + alink(\"..\", { peer: st.peer, bucket: st.bucket, path: parentPath(path) }) + \"</p>\";\n    html += \"<h1><span class='live'></span>\" + esc(path || \"/\") + \"</h1>\";\n\n    if (!keys.length) {\n      html += \"<p class='muted'>Loading...</p>\";\n      app.innerHTML = html;\n      return;\n    }\n\n    if (kids.length) {\n      html += \"<div class='section'><h2>Children</h2><ul>\";\n      for (var i = 0; i < kids.length; i++) {\n        var child = kids[i];\n        var label = parts(child).slice(-1)[0];\n        html += \"<li>\" + alink(label, { peer: st.peer, bucket: st.bucket, path: child }) + \"</li>\";\n      }\n      html += \"</ul></div>\";\n    }\n\n    if (!isNode) {\n      if (!path) {\n        app.innerHTML = html;\n        return;\n      }\n      html += \"<p class='muted'>No node at this path.</p>\";\n      app.innerHTML = html;\n      return;\n    }\n\n    if (!view.nodeLoaded) {\n      html += \"<p class='muted'>Loading node...</p>\";\n      app.innerHTML = html;\n      return;\n    }\n\n    if (!view.node) {\n      html += \"<p class='muted'>Node is empty or missing.</p>\";\n      app.innerHTML = html;\n      return;\n    }\n\n    var node = view.node;\n\n    html += \"<div class='section'><h2>Node</h2>\";\n    html += \"<pre>\" + esc(JSON.stringify(node, null, 2)) + \"</pre></div>\";\n\n    var links = normalizeLinks(node, st);\n    if (links.length) {\n      html += \"<div class='section'><h2>Links</h2><ul>\";\n      for (var j = 0; j < links.length; j++) {\n        var it = links[j];\n        html += \"<li>\" + alink(it.label, { peer: it.peer, bucket: it.bucket, path: it.path }) + \"</li>\";\n      }\n      html += \"</ul></div>\";\n    }\n\n    if (node.html) {\n      html += \"<div class='section'><h2>Rendered HTML</h2>\";\n      html += \"<div data-rendered-html>\" + String(node.html) + \"</div>\";\n      html += \"</div>\";\n    }\n\n    app.innerHTML = html;\n  }\n\n  app.addEventListener(\"click\", function (e) {\n    var el = e.target.closest(\"[data-rendered-html] a\");\n    if (!el) return;\n\n    var st = parseHash();\n    var href = String(el.getAttribute(\"href\") || \"\").trim();\n\n    if (href && href !== \"#\") {\n      if (href.charAt(0) === \"#\") {\n        e.preventDefault();\n        location.hash = href;\n        return;\n      }\n      if (!/^(https?:|mailto:|tel:|javascript:)/i.test(href)) {\n        e.preventDefault();\n        location.hash = makeHash({ peer: st.peer, bucket: st.bucket, path: href.replace(/^\\/+/, \"\") });\n        return;\n      }\n      return;\n    }\n\n    var path = String(el.getAttribute(\"data-path\") || el.textContent || \"\").trim();\n    if (!path) return;\n    e.preventDefault();\n    location.hash = makeHash({ peer: st.peer, bucket: st.bucket, path: path });\n  });\n\n  function route() {\n    var st = parseHash();\n    view.peer = st.peer;\n    view.bucket = st.bucket;\n    view.path = st.path;\n    view.node = null;\n    view.nodeLoaded = false;\n    view.nodeSig = \"\";\n\n    if (!st.peer || !st.bucket) {\n      stopNodeSub();\n      view.nodeLoaded = true;\n      renderCurrentView();\n      return;\n    }\n\n    ensureMapSub(st.peer, st.bucket);\n    watchNode(st.peer, st.bucket, st.path);\n    renderCurrentView();\n  }\n\n  window.addEventListener(\"hashchange\", route);\n  route();\n})();\n",">":1774597091512.007}},"layer":{"":{":":9999,">":1774597091512.007}}}},"\u001b":{"data/":{"index":{"":{":":{"#":"demo3/scene/data/index"},">":1774597052858}},"services/":{"api":{"":{":":{"#":"demo3/scene/data/services/api"},">":1774597117437}},"db":{"":{":":{"#":"demo3/scene/data/services/db"},">":1774597117437.006}},"cache":{"":{":":{"#":"demo3/scene/data/services/cache"},">":1774597117437.012}},"queue":{"":{":":{"#":"demo3/scene/data/services/queue"},">":1774597117437.018}},"st":{"orage":{"":{":":{"#":"demo3/scene/data/services/storage"},">":1774597117437.024}},"atus":{"":{":":{"#":"demo3/scene/data/services/status"},">":1774597117438.004}}}},"weather/index":{"":{":":{"#":"demo3/scene/data/weather/index"},">":1774597117439.027}},"users/index":{"":{":":{"#":"demo3/scene/data/users/index"},">":1774597117436.01}},"logs/latest":{"":{":":{"#":"demo3/scene/data/logs/latest"},">":1774597117436.0151}}},"_machines/Minis-Mac-mini.local-":{"0":{"7663933/info":{"":{":":{"#":"demo3/scene/_machines/Minis-Mac-mini.local-07663933/info"},">":1774597091499.004}},"d796b6f/info":{"":{":":{"#":"demo3/scene/_machines/Mi