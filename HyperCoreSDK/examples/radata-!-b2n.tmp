   subtree: true,\n    characterData: true\n  });\n\n  setTimeout(scrollToBottom, 50);\n})();\n",">":1773274910155}},"analysis_":{"c":{"hoice":{"":{":":"Chosen move: parsing...",">":1773274986399}},"ontent":{"":{":":"",">":1773274986399}}},"t":{"hinking":{"":{":":"Thinking disabled for compatibility mode.",">":1773274986399}},"itle":{"":{":":"White · qwen3:14b is deciding…",">":1773274986399}}}},"black_":{"model":{"":{":":"gemma3:12b",">":1773274911415}},"score":{"":{":":"0",">":1773274911415}}},"c":{"andidate_":{"1":{"":{":":"",">":1773274986399}},"2":{"":{":":"",">":1773274986399}},"3":{"":{":":"",">":1773274986399}}},"ompleted_games":{"":{":":"0",">":1773274911415}}},"draw_score":{"":{":":"0",">":1773274911415}},"game_label":{"":{":":"Game 1",">":1773274911415}},"la":{"yer":{"":{":":10,">":1773274910155}},"st_move":{"":{":":"—",">":1773274911415}}},"s":{"0":{"":{":":"♜",">":1773274911415}},"1":{"0":{"":{":":"♟",">":1773274911415}},"1":{"":{":":"♟",">":1773274911415}},"2":{"":{":":"♟",">":1773274911415}},"3":{"":{":":"♟",">":1773274911415}},"4":{"":{":":"♟",">":1773274911415}},"5":{"":{":":"♟",">":1773274911415}},"6":{"":{":":"",">":1773274911415}},"7":{"":{":":"",">":1773274911415}},"8":{"":{":":"",">":1773274911415}},"9":{"":{":":"",">":1773274911415}},"":{":":"♞",">":1773274911415}},"2":{"0":{"":{":":"",">":1773274911415}},"1":{"":{":":"",">":1773274911415}},"2":{"":{":":"",">":1773274911415}},"3":{"":{":":"",">":1773274911415}},"4":{"":{":":"",">":1773274911415}},"5":{"":{":":"",">":1773274911415}},"6":{"":{":":"",">":1773274911415}},"7":{"":{":":"",">":1773274911415}},"8":{"":{":":"",">":1773274911415}},"9":{"":{":":"",">":1773274911415}},"":{":":"♝",">":1773274911415}},"3":{"0":{"":{":":"",">":1773274911415}},"1":{"":{":":"",">":1773274911415}},"2":{"":{":":"",">":1773274911415}},"3":{"":{":":"",">":1773274911415}},"4":{"":{":":"",">":1773274911415}},"5":{"":{":":"",">":1773274911415}},"6":{"":{":":"",">":1773274911415}},"7":{"":{":":"",">":1773274911415}},"