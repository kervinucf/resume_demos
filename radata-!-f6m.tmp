{"demo111":{"/scene":{"/weather/nyc":{"\u001bdata":{"":{":":{"#":"demo111/scene/weather/nyc/data"},">":1774768661826}},"/":{"data\u001b":{"temp":{"":{":":69,">":1774768661826}},"c":{"ity":{"":{":":"New York",">":1774768661826}},"ond":{"":{":":"Rain",">":1774768661826}}},"units":{"":{":":"°F",">":1774768661826}},"note":{"":{":":"source-node-5743",">":1774768661826}}},"panel\u001b":{"html":{"":{":":"\n<div style=\"font-family:monospace;padding:16px\">\n  <div>city: <span id=\"top-city\" data-bind-text=\"city\"></span></div>\n  <div>temp: <span id=\"top-temp\" data-bind-text=\"temp\"></span></div>\n  <div>cond: <span id=\"top-cond\" data-bind-text=\"cond\"></span></div>\n  <div>units: <span id=\"top-units\" data-bind-text=\"units\"></span></div>\n  <div>note: <span id=\"top-note\" data-bind-text=\"note\"></span></div>\n</div>\n",">":1774768656550}},"css":{"":{":":"",">":1774768656550}},"js":{"":{":":"\n(function(){\n  function txt(id){\n    var el = document.getElementById(id);\n    return el ? el.textContent : null;\n  }\n  function dump(tag){\n    var payload = {\n      tag: tag,\n      href: location.href,\n      hyperContext: window.hyperContext || window.hyper_context || null,\n      dom: {\n        city: txt('top-city'),\n        temp: txt('top-temp'),\n        cond: txt('top-cond'),\n        units: txt('top-units'),\n        note: txt('top-note')\n      }\n    };\n    var pre = document.getElementById('dom-dump');\n    if (pre) pre.textContent = JSON.stringify(payload, null, 2);\n    console.log('[PANEL DEBUG]', payload);\n  }\n  dump('boot');\n  setTimeout(function(){ dump('t+250ms'); }, 250);\n  setTimeout(function(){ dump('t+1000ms'); }, 1000);\n  setInterval(function(){ dump('interval'); }, 2000);\n})();\n",">":1774768656550}},"fixed":{"":{":":false,">":1774768656550}},"layer":{"":{":":0,">":1774768656550}}}}},"\u001bweather/nyc":{"":{":":{"#":"demo111/scene/weather/nyc"},">":1774768661826},"/panel":{"":{":":{"#":"demo111/scene/weather/nyc/panel"},">":1774768656550}}}},"\u001bscene":{"":{":":{"#":"demo111/scene"},">":1774768661826}}}}